{
  "manifest_version": 2,
  "applications": {
    "gecko": {
      "id": "gconversation@xulforum.org",
      "strict_min_version": "140.0a1",
      "strict_max_version": "154.0a1"
    }
  },
  "author": "Jonathan Protzenko",
  "name": "__MSG_extensionName__",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "version": "4.3.10",
  "homepage_url": "http://github.com/thunderbird-conversations/thunderbird-conversations/wiki",
  "background": {
    "scripts": ["background/background.mjs"],
    "type": "module"
  },
  "icons": {
    "32": "icon.png"
  },
  "options_ui": {
    "open_in_tab": true,
    "page": "options/options.html"
  },
  "permissions": [
    "accountsRead",
    "addressBooks",
    "messagesRead",
    "messagesModifyPermanent",
    "messagesMove",
    "messagesDelete",
    "messagesUpdate",
    "messagesTags",
    "messagesTagsList",
    "storage",
    "tabs"
  ],
  "experiment_apis": {
    "conversations": {
      "schema": "experiment-api/apis/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["conversations"]],
        "script": "experiment-api/apis/api.js",
        "events": ["startup"]
      }
    },
    "convCalendar": {
      "schema": "experiment-api/apis/calendarSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convCalendar"]],
        "script": "experiment-api/apis/calendarApi.js"
      }
    },
    "convCompose": {
      "schema": "experiment-api/apis/composeSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convCompose"]],
        "script": "experiment-api/apis/composeApi.js"
      }
    },
    "convContacts": {
      "schema": "experiment-api/apis/contactsSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convContacts"]],
        "script": "experiment-api/apis/contactsApi.js"
      }
    },
    "convGloda": {
      "schema": "experiment-api/apis/glodaSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convGloda"]],
        "script": "experiment-api/apis/glodaApi.js"
      }
    },
    "convMsgWindow": {
      "schema": "experiment-api/apis/msgWindowSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convMsgWindow"]],
        "script": "experiment-api/apis/msgWindowApi.js"
      }
    },
    "convOpenPgp": {
      "schema": "experiment-api/apis/openPgpSchema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["convOpenPgp"]],
        "script": "experiment-api/apis/openPgpApi.js"
      }
    }
  },
  "commands": {
    "quick_compose": {
      "suggested_key": {
        "default": "Ctrl+Shift+N"
      },
      "description": "Open the quick compose window"
    }
  }
}
